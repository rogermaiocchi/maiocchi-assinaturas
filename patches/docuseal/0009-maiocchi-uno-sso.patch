diff --git a/app/controllers/maiocchi_sso_controller.rb b/app/controllers/maiocchi_sso_controller.rb
new file mode 100644
index 0000000000000000000000000000000000000000..e7f1d9d03a498c92b2f398282823d4c3176ee290
--- /dev/null
+++ b/app/controllers/maiocchi_sso_controller.rb
@@ -0,0 +1,116 @@
+# frozen_string_literal: true
+
+require 'base64'
+require 'digest'
+
+class MaiocchiSsoController < ApplicationController
+  skip_authorization_check
+  skip_before_action :authenticate_user!
+  skip_before_action :maybe_redirect_to_setup
+
+  before_action :set_private_response_headers
+  before_action :ensure_exact_callback_host!
+  before_action :ensure_enabled!
+
+  rescue_from MaiocchiSso::FlowError, ActionController::ParameterMissing do
+    clear_flow!
+    render plain: 'Não foi possível concluir o acesso integrado. Inicie uma nova tentativa.',
+           status: :unprocessable_content
+  end
+
+  def start
+    return redirect_to(dashboard_index_path, status: :see_other) if signed_in?
+
+    reset_session
+    state = random_browser_value(32)
+    nonce = random_browser_value(32)
+    verifier = random_browser_value(64)
+    session[:maiocchi_sso] = {
+      'state_sha256' => Digest::SHA256.hexdigest(state),
+      'nonce' => nonce,
+      'verifier' => verifier,
+      'issued_at' => Time.current.to_i
+    }
+
+    redirect_to authorization_url(state:, nonce:, verifier:), allow_other_host: true, status: :see_other
+  end
+
+  def callback
+    raise MaiocchiSso::FlowError unless request.query_parameters.keys.sort == %w[code state]
+
+    flow = session.delete(:maiocchi_sso)
+    raise MaiocchiSso::FlowError unless valid_flow?(flow, params.require(:state))
+
+    code = params.require(:code).to_s
+    raise MaiocchiSso::FlowError unless code.match?(/\A[A-Za-z0-9_-]{43}\z/)
+
+    claims = MaiocchiSso::TokenExchange.call(
+      code:,
+      verifier: flow.fetch('verifier'),
+      nonce: flow.fetch('nonce')
+    )
+    user = MaiocchiSso::IdentityResolver.call(claims)
+
+    reset_session
+    sign_in(:user, user)
+    redirect_to dashboard_index_path, notice: 'Acesso integrado realizado com segurança.', status: :see_other
+  end
+
+  private
+
+  def ensure_exact_callback_host!
+    raise MaiocchiSso::FlowError unless request.ssl?
+    raise MaiocchiSso::FlowError unless request.host.downcase == MaiocchiSso::Configuration.callback_host
+  end
+
+  def ensure_enabled!
+    MaiocchiSso::Configuration.validate!
+  end
+
+  def authorization_url(state:, nonce:, verifier:)
+    uri = URI.parse(MaiocchiSso::Configuration::AUTHORIZE_URL)
+    uri.query = URI.encode_www_form(
+      response_type: 'code',
+      client_id: MaiocchiSso::Configuration::CLIENT_ID,
+      redirect_uri: MaiocchiSso::Configuration::REDIRECT_URI,
+      code_challenge: Base64.urlsafe_encode64(Digest::SHA256.digest(verifier), padding: false),
+      code_challenge_method: 'S256',
+      state:,
+      nonce:,
+      scope: MaiocchiSso::Configuration::SCOPE,
+      audience: MaiocchiSso::Configuration::AUDIENCE
+    )
+    uri.to_s
+  end
+
+  def valid_flow?(flow, returned_state)
+    return false unless flow.is_a?(Hash)
+    return false unless returned_state.is_a?(String) && returned_state.match?(/\A[A-Za-z0-9_-]{43}\z/)
+    return false unless flow['nonce'].to_s.match?(/\A[A-Za-z0-9_-]{43}\z/)
+    return false unless flow['verifier'].to_s.match?(/\A[A-Za-z0-9_-]{43,128}\z/)
+
+    issued_at = Integer(flow['issued_at'], exception: false)
+    return false unless issued_at
+
+    age = Time.current.to_i - issued_at
+    return false unless age.between?(0, MaiocchiSso::Configuration::FLOW_TTL.to_i)
+
+    actual = Digest::SHA256.hexdigest(returned_state)
+    expected = flow['state_sha256'].to_s
+    expected.bytesize == actual.bytesize && ActiveSupport::SecurityUtils.secure_compare(expected, actual)
+  end
+
+  def random_browser_value(bytes)
+    SecureRandom.urlsafe_base64(bytes, false)
+  end
+
+  def clear_flow!
+    session.delete(:maiocchi_sso)
+  end
+
+  def set_private_response_headers
+    response.headers['Cache-Control'] = 'no-store'
+    response.headers['Pragma'] = 'no-cache'
+    response.headers['Referrer-Policy'] = 'no-referrer'
+  end
+end
