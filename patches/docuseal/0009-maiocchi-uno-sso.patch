@@ -0,0 +1,23 @@
+# frozen_string_literal: true
+
+class MaiocchiSsoIdentity < ApplicationRecord
+  BINDING_FIELDS = %w[provider subject account_id user_id email_at_link].freeze
+
+  belongs_to :account
+  belongs_to :user
+  has_many :maiocchi_sso_exchanges, dependent: :restrict_with_exception
+
+  validates :provider, inclusion: { in: [MaiocchiSso::Configuration::PROVIDER] }
+  validates :subject, format: { with: MaiocchiSso::Configuration::UUID_PATTERN }
+  validates :email_at_link, length: { maximum: 320 }, format: { with: User::FULL_EMAIL_REGEXP }
+  validates :external_role, inclusion: { in: MaiocchiSso::Configuration::ALLOWED_EXTERNAL_ROLES }
+  validate :binding_is_immutable, on: :update
+
+  private
+
+  def binding_is_immutable
+    return unless BINDING_FIELDS.any? { |field| will_save_change_to_attribute?(field) }
+
+    errors.add(:base, 'SSO identity binding is immutable')
+  end
+end
