@@ -0,0 +1,87 @@
+# frozen_string_literal: true
+
+require 'uri'
+
+module MaiocchiSso
+  module Configuration
+    PROVIDER = 'maiocchi_uno'
+    CLIENT_ID = 'maiocchi-signature'
+    ISSUER = 'https://www.maiocchi.adv.br'
+    AUTHORIZE_URL = 'https://www.maiocchi.adv.br/api/auth/sso/authorize'
+    TOKEN_URL = 'https://www.maiocchi.adv.br/api/auth/sso/token'
+    REDIRECT_URI = 'https://assinatura.maiocchi.adv.br/sso/maiocchi/callback'
+    AUDIENCE = 'maiocchi-signature'
+    SCOPE = 'openid profile signature.manage'
+    TOKEN_TYPE = 'urn:maiocchi:backchannel-identity'
+    ALLOWED_EXTERNAL_ROLES = %w[admin advogado staff].freeze
+    LOCAL_ROLE = User::ADMIN_ROLE
+    FLOW_TTL = 5.minutes
+    MAX_TOKEN_TTL_SECONDS = 30
+    UUID_PATTERN = /\A[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}\z/
+
+    module_function
+
+    def enabled?
+      ENV['MAIOCCHI_SSO_ENABLED'] == 'true'
+    end
+
+    def account_uuid
+      exact_uuid!(ENV['MAIOCCHI_SSO_ACCOUNT_UUID'], 'account allowlist')
+    end
+
+    def bootstrap_user_uuid
+      value = ENV['MAIOCCHI_SSO_BOOTSTRAP_USER_UUID'].presence
+      value && exact_uuid!(value, 'bootstrap user')
+    end
+
+    def client_secret
+      value = read_secret_file || ENV['MAIOCCHI_SSO_CLIENT_SECRET'].to_s
+      raise ConfigurationError, 'SSO client credential is unavailable' unless value.bytesize.between?(32, 512)
+      raise ConfigurationError, 'SSO client credential is malformed' if value.match?(/[\0\r\n]/)
+
+      value
+    end
+
+    def validate!
+      raise ConfigurationError, 'SSO is disabled' unless enabled?
+
+      account_uuid
+      bootstrap_user_uuid
+      client_secret
+      [ISSUER, AUTHORIZE_URL, TOKEN_URL, REDIRECT_URI].each do |value|
+        uri = URI.parse(value)
+        raise ConfigurationError, 'SSO endpoint is not exact HTTPS' unless uri.is_a?(URI::HTTPS)
+        raise ConfigurationError, 'SSO endpoint contains userinfo' if uri.userinfo
+        raise ConfigurationError, 'SSO endpoint contains a fragment' if uri.fragment
+      end
+      true
+    rescue URI::InvalidURIError
+      raise ConfigurationError, 'SSO endpoint is invalid'
+    end
+
+    def callback_host
+      URI.parse(REDIRECT_URI).host
+    end
+
+    def exact_uuid!(value, label)
+      normalized = value.to_s.downcase
+      raise ConfigurationError, "SSO #{label} is invalid" unless normalized.match?(UUID_PATTERN)
+
+      normalized
+    end
+    private_class_method :exact_uuid!
+
+    def read_secret_file
+      path = ENV['MAIOCCHI_SSO_CLIENT_SECRET_FILE'].presence
+      return if path.nil?
+
+      stat = File.stat(path)
+      raise ConfigurationError, 'SSO client credential file is invalid' unless stat.file? && stat.size.between?(32, 513)
+
+      File.binread(path, 513).delete_suffix("\n")
+    rescue Errno::ENOENT, Errno::EACCES, Errno::EISDIR, SystemCallError
+      raise ConfigurationError, 'SSO client credential file is unavailable'
+    end
+    private_class_method :read_secret_file
+  end
+end
diff --git a/lib/maiocchi_sso/identity_resolver.rb b/lib/maiocchi_sso/identity_resolver.rb
new file mode 100644
index 0000000000000000000000000000000000000000..8e79c0fca3521fa1ab565fce0c7eabfd6e559231
--- /dev/null
+++ b/lib/maiocchi_sso/identity_resolver.rb
@@ -0,0 +1,109 @@
+# frozen_string_literal: true
+
+module MaiocchiSso
+  class IdentityResolver
+    def self.call(claims, now: Time.current)
+      new(claims, now:).call
+    end
+
+    def initialize(claims, now:)
+      @claims = claims
+      @now = now
+    end
+
+    def call
+      identity = nil
+
+      ActiveRecord::Base.transaction do
+        account = Account.active.lock.find_by!(uuid: MaiocchiSso::Configuration.account_uuid)
+        identity = MaiocchiSsoIdentity.lock.find_by(
+          provider: MaiocchiSso::Configuration::PROVIDER,
+          subject: @claims.fetch('subject')
+        )
+        identity ||= link_identity!(account)
+        validate_existing_identity!(identity, account)
+        record_exchange!(identity)
+        identity.update!(external_role: @claims.fetch('role'), last_authenticated_at: @now)
+      end
+
+      identity.user
+    rescue ActiveRecord::RecordInvalid, ActiveRecord::RecordNotFound, ActiveRecord::RecordNotUnique,
+           KeyError, MaiocchiSso::ConfigurationError
+      raise MaiocchiSso::FlowError, 'SSO identity rejected'
+    end
+
+    private
+
+    def link_identity!(account)
+      email = normalized_email
+      user = bootstrap_user(account, email) || provision_user!(account, email)
+
+      MaiocchiSsoIdentity.create!(
+        account:,
+        user:,
+        provider: MaiocchiSso::Configuration::PROVIDER,
+        subject: @claims.fetch('subject'),
+        email_at_link: email,
+        external_role: @claims.fetch('role'),
+        last_authenticated_at: @now
+      )
+    end
+
+    def bootstrap_user(account, email)
+      uuid = MaiocchiSso::Configuration.bootstrap_user_uuid
+      return if uuid.nil?
+
+      user = User.active.lock.find_by!(uuid:, account:)
+      raise MaiocchiSso::FlowError unless user.email.casecmp?(email)
+      raise MaiocchiSso::FlowError unless user.role == MaiocchiSso::Configuration::LOCAL_ROLE
+      raise MaiocchiSso::FlowError if MaiocchiSsoIdentity.exists?(provider: MaiocchiSso::Configuration::PROVIDER,
+                                                                  user:)
+
+      user
+    end
+
+    def provision_user!(account, email)
+      raise MaiocchiSso::FlowError if User.where('LOWER(email) = ?', email).exists?
+
+      first_name, last_name = normalized_names
+      User.create!(
+        account:,
+        email:,
+        first_name:,
+        last_name:,
+        role: MaiocchiSso::Configuration::LOCAL_ROLE,
+        **{ :password => SecureRandom.urlsafe_base64(48) }
+      )
+    end
+
+    def validate_existing_identity!(identity, account)
+      user = identity.user
+      raise MaiocchiSso::FlowError unless identity.account_id == account.id && user.account_id == account.id
+      raise MaiocchiSso::FlowError unless identity.email_at_link.casecmp?(normalized_email)
+      raise MaiocchiSso::FlowError unless user.email.casecmp?(normalized_email)
+      raise MaiocchiSso::FlowError unless user.role == MaiocchiSso::Configuration::LOCAL_ROLE
+      raise MaiocchiSso::FlowError unless user.active_for_authentication?
+      raise MaiocchiSso::FlowError unless @claims.fetch('role').in?(MaiocchiSso::Configuration::ALLOWED_EXTERNAL_ROLES)
+    end
+
+    def record_exchange!(identity)
+      MaiocchiSsoExchange.create!(
+        maiocchi_sso_identity: identity,
+        provider: MaiocchiSso::Configuration::PROVIDER,
+        exchange_id: @claims.fetch('exchange_id'),
+        observed_at: @now
+      )
+    end
+
+    def normalized_email
+      @normalized_email ||= @claims.fetch('email').to_s.strip.downcase.tap do |email|
+        raise MaiocchiSso::FlowError unless email.match?(User::FULL_EMAIL_REGEXP)
+      end
+    end
+
+    def normalized_names
+      parts = @claims['name'].to_s.strip.split(/\s+/, 2)
+      [parts.first.presence, parts.second.presence]
+    end
+  end
+end
diff --git a/lib/maiocchi_sso/token_exchange.rb b/lib/maiocchi_sso/token_exchange.rb
new file mode 100644
index 0000000000000000000000000000000000000000..6b8fc7b125ad03e9ad82230b7d78f4bff367200a
--- /dev/null
+++ b/lib/maiocchi_sso/token_exchange.rb
@@ -0,0 +1,131 @@
+# frozen_string_literal: true
+
+require 'json'
+require 'net/http'
+require 'time'
+require 'uri'
+
+module MaiocchiSso
+  class TokenExchange
+    MAX_RESPONSE_BYTES = 32.kilobytes
+    REQUIRED_KEYS = %w[
+      ok token_type expires_in issued_at expires_at issuer audience scope nonce subject email name role
+      auth_time exchange_id
+    ].freeze
+    EMAIL_PATTERN = /\A[A-Za-z0-9.!#$%&'*+\/=?^_`{|}~-]+@[A-Za-z0-9](?:[A-Za-z0-9-]{0,61}[A-Za-z0-9])?(?:\.[A-Za-z0-9](?:[A-Za-z0-9-]{0,61}[A-Za-z0-9])?)+\z/
+
+    def self.call(code:, verifier:, nonce:, now: Time.current)
+      new(code:, verifier:, nonce:, now:).call
+    end
+
+    def initialize(code:, verifier:, nonce:, now:)
+      @code = code
+      @verifier = verifier
+      @nonce = nonce
+      @now = now
+    end
+
+    def call
+      MaiocchiSso::Configuration.validate!
+      started_at = Process.clock_gettime(Process::CLOCK_MONOTONIC)
+      response = perform_request
+      elapsed = Process.clock_gettime(Process::CLOCK_MONOTONIC) - started_at
+      claims = parse_response(response)
+      validate_claims!(claims, elapsed:)
+      claims
+    rescue JSON::ParserError, URI::InvalidURIError, Timeout::Error, SocketError, SystemCallError,
+           OpenSSL::SSL::SSLError, Net::HTTPBadResponse, Net::HTTPHeaderSyntaxError,
+           MaiocchiSso::ConfigurationError => e
+      Rails.logger.warn(event: 'maiocchi_sso_exchange_failed', error_class: e.class.name)
+      raise MaiocchiSso::FlowError, 'SSO exchange failed'
+    end
+
+    private
+
+    def perform_request
+      uri = URI.parse(MaiocchiSso::Configuration::TOKEN_URL)
+      raise MaiocchiSso::FlowError unless uri.is_a?(URI::HTTPS) && uri.userinfo.nil? && uri.fragment.nil?
+
+      request = Net::HTTP::Post.new(uri)
+      request.basic_auth(MaiocchiSso::Configuration::CLIENT_ID, MaiocchiSso::Configuration.client_secret)
+      request['Accept'] = 'application/json'
+      request['Content-Type'] = 'application/x-www-form-urlencoded'
+      request['Cache-Control'] = 'no-store'
+      request.body = URI.encode_www_form(
+        grant_type: 'authorization_code',
+        code: @code,
+        redirect_uri: MaiocchiSso::Configuration::REDIRECT_URI,
+        code_verifier: @verifier,
+        nonce: @nonce
+      )
+
+      Net::HTTP.start(uri.host, uri.port, use_ssl: true, verify_mode: OpenSSL::SSL::VERIFY_PEER,
+                                          open_timeout: 3, read_timeout: 5, write_timeout: 5) do |http|
+        http.request(request) do |response|
+          raise MaiocchiSso::FlowError unless response.is_a?(Net::HTTPSuccess)
+          raise MaiocchiSso::FlowError unless response['content-type'].to_s.split(';').first == 'application/json'
+
+          declared_length = Integer(response['content-length'], exception: false)
+          raise MaiocchiSso::FlowError if declared_length && declared_length > MAX_RESPONSE_BYTES
+
+          body = +''
+          response.read_body do |chunk|
+            raise MaiocchiSso::FlowError if body.bytesize + chunk.bytesize > MAX_RESPONSE_BYTES
+
+            body << chunk
+          end
+          return body
+        end
+      end
+    end
+
+    def parse_response(body)
+      JSON.parse(body)
+    end
+
+    def validate_claims!(claims, elapsed:)
+      raise MaiocchiSso::FlowError unless claims.is_a?(Hash) && claims.keys.sort == REQUIRED_KEYS.sort
+      raise MaiocchiSso::FlowError unless claims['ok'] == true
+      raise MaiocchiSso::FlowError unless claims['token_type'] == MaiocchiSso::Configuration::TOKEN_TYPE
+      raise MaiocchiSso::FlowError unless claims['issuer'] == MaiocchiSso::Configuration::ISSUER
+      raise MaiocchiSso::FlowError unless claims['audience'] == MaiocchiSso::Configuration::AUDIENCE
+      raise MaiocchiSso::FlowError unless claims['scope'] == MaiocchiSso::Configuration::SCOPE
+      raise MaiocchiSso::FlowError unless secure_equal?(claims['nonce'], @nonce)
+      raise MaiocchiSso::FlowError unless claims['subject'].to_s.match?(MaiocchiSso::Configuration::UUID_PATTERN)
+      raise MaiocchiSso::FlowError unless claims['exchange_id'].to_s.match?(MaiocchiSso::Configuration::UUID_PATTERN)
+      raise MaiocchiSso::FlowError unless claims['role'].in?(MaiocchiSso::Configuration::ALLOWED_EXTERNAL_ROLES)
+      raise MaiocchiSso::FlowError unless valid_email?(claims['email'])
+      raise MaiocchiSso::FlowError unless claims['name'].nil? || valid_name?(claims['name'])
+
+      ttl = claims['expires_in']
+      raise MaiocchiSso::FlowError unless ttl.is_a?(Integer) && ttl.between?(1, MaiocchiSso::Configuration::MAX_TOKEN_TTL_SECONDS)
+
+      issued_at = Time.iso8601(claims['issued_at'].to_s)
+      expires_at = Time.iso8601(claims['expires_at'].to_s)
+      absolute_ttl = expires_at - issued_at
+      remaining = expires_at - @now
+      raise MaiocchiSso::FlowError unless issued_at.between?(@now - 30.seconds, @now + 5.seconds)
+      raise MaiocchiSso::FlowError unless absolute_ttl.positive? && absolute_ttl <= MaiocchiSso::Configuration::MAX_TOKEN_TTL_SECONDS
+      raise MaiocchiSso::FlowError unless absolute_ttl == ttl && remaining.positive?
+      raise MaiocchiSso::FlowError unless elapsed >= 0 && elapsed < remaining
+
+      auth_time = Time.iso8601(claims['auth_time'].to_s)
+      raise MaiocchiSso::FlowError if auth_time > issued_at || auth_time < @now - 30.days
+    rescue ArgumentError
+      raise MaiocchiSso::FlowError
+    end
+
+    def valid_email?(value)
+      value.is_a?(String) && value.bytesize.between?(3, 320) && value.match?(EMAIL_PATTERN)
+    end
+
+    def valid_name?(value)
+      value.is_a?(String) && value.strip.present? && value.bytesize <= 200 && !value.match?(/[\0\r\n]/)
+    end
+
+    def secure_equal?(left, right)
+      left.is_a?(String) && right.is_a?(String) && left.bytesize == right.bytesize &&
+        ActiveSupport::SecurityUtils.secure_compare(left, right)
+    end
+  end
+end
diff --git a/spec/lib/maiocchi_sso_configuration_spec.rb b/spec/lib/maiocchi_sso_configuration_spec.rb
new file mode 100644
index 0000000000000000000000000000000000000000..a8da6782b6edc884d4c3a080435ff40f3820ee38
--- /dev/null
+++ b/spec/lib/maiocchi_sso_configuration_spec.rb
@@ -0,0 +1,47 @@
+# frozen_string_literal: true
+
+require 'tempfile'
+
+RSpec.describe MaiocchiSso::Configuration do
+  around do |example|
+    keys = %w[
+      MAIOCCHI_SSO_ENABLED MAIOCCHI_SSO_ACCOUNT_UUID MAIOCCHI_SSO_BOOTSTRAP_USER_UUID
+      MAIOCCHI_SSO_CLIENT_SECRET MAIOCCHI_SSO_CLIENT_SECRET_FILE
+    ]
+    previous = ENV.to_h.slice(*keys)
+    keys.each { |key| ENV.delete(key) }
+    example.run
+  ensure
+    keys.each { |key| ENV.delete(key) }
+    previous.each { |key, value| ENV[key] = value }
+  end
+
+  it 'fails closed unless enabled with exact account allowlist and a strong client credential' do
+    expect { described_class.validate! }.to raise_error(MaiocchiSso::ConfigurationError)
+
+    ENV['MAIOCCHI_SSO_ENABLED'] = 'true'
+    ENV['MAIOCCHI_SSO_ACCOUNT_UUID'] = SecureRandom.uuid
+    ENV['MAIOCCHI_SSO_CLIENT_SECRET'] = 'short'
+    expect { described_class.validate! }.to raise_error(MaiocchiSso::ConfigurationError)
+
+    ENV['MAIOCCHI_SSO_CLIENT_SECRET'] = 's' * 48
+    expect(described_class.validate!).to be(true)
+  end
+
+  it 'prefers a bounded secret file and never accepts embedded line breaks' do
+    Tempfile.create('sso-client-secret') do |file|
+      file.binmode
+      file.write(('f' * 48) + "\n")
+      file.flush
+      ENV['MAIOCCHI_SSO_CLIENT_SECRET_FILE'] = file.path
+      ENV['MAIOCCHI_SSO_CLIENT_SECRET'] = 'e' * 48
+      expect(described_class.client_secret).to eq('f' * 48)
+
+      file.rewind
+      file.truncate(0)
+      file.write("#{'f' * 32}\nsecond-line")
+      file.flush
+      expect { described_class.client_secret }.to raise_error(MaiocchiSso::ConfigurationError)
+    end
+  end
+end
diff --git a/spec/lib/maiocchi_sso_identity_resolver_spec.rb b/spec/lib/maiocchi_sso_identity_resolver_spec.rb
new file mode 100644
index 0000000000000000000000000000000000000000..c462fafe5b433d5f0068223ccb42d6aa19e82c23
--- /dev/null
+++ b/spec/lib/maiocchi_sso_identity_resolver_spec.rb
@@ -0,0 +1,101 @@
+# frozen_string_literal: true
+
+RSpec.describe MaiocchiSso::IdentityResolver do
+  let(:account) { create(:account) }
+  let(:now) { Time.utc(2026, 7, 18, 12) }
+  let(:claims) do
+    {
+      'subject' => 'f3065564-0e72-480f-bd82-60d951ab909b',
+      'email' => 'advogado@maiocchi.adv.br',
+      'name' => 'Advogado Maiocchi',
+      'role' => 'advogado',
+      'exchange_id' => SecureRandom.uuid
+    }
+  end
+
+  before do
+    allow(MaiocchiSso::Configuration).to receive(:account_uuid).and_return(account.uuid)
+    allow(MaiocchiSso::Configuration).to receive(:bootstrap_user_uuid).and_return(nil)
+  end
+
+  it 'provisions only into the allowlisted account and persists subject binding plus exchange ledger' do
+    user = described_class.call(claims, now:)
+
+    identity = MaiocchiSsoIdentity.find_by!(subject: claims.fetch('subject'))
+    expect(user.account).to eq(account)
+    expect(user.role).to eq(User::ADMIN_ROLE)
+    expect(user.email).to eq(claims.fetch('email'))
+    expect(identity).to have_attributes(account:, user:, email_at_link: claims.fetch('email'),
+                                        external_role: 'advogado', last_authenticated_at: now)
+    expect(identity.maiocchi_sso_exchanges.sole.exchange_id).to eq(claims.fetch('exchange_id'))
+  end
+
+  it 'rejects replay of a previously accepted exchange id' do
+    described_class.call(claims, now:)
+
+    expect { described_class.call(claims, now: now + 1.second) }
+      .to raise_error(MaiocchiSso::FlowError)
+    expect(MaiocchiSsoExchange.count).to eq(1)
+  end
+
+  it 'keeps the identity binding immutable and the exchange ledger append-only' do
+    user = described_class.call(claims, now:)
+    identity = user.maiocchi_sso_identity
+
+    expect { identity.update!(subject: SecureRandom.uuid) }.to raise_error(ActiveRecord::RecordInvalid)
+    expect(identity.reload.subject).to eq(claims.fetch('subject'))
+    expect { identity.maiocchi_sso_exchanges.sole.destroy! }.to raise_error(ActiveRecord::ReadOnlyRecord)
+  end
+
+  it 'rejects email collision instead of taking over an existing local user' do
+    existing = create(:user, email: claims.fetch('email'))
+
+    expect { described_class.call(claims, now:) }.to raise_error(MaiocchiSso::FlowError)
+    expect(existing.reload.maiocchi_sso_identity).to be_nil
+    expect(MaiocchiSsoIdentity.count).to eq(0)
+  end
+
+  it 'links an explicitly allowlisted bootstrap user without relying on email discovery' do
+    bootstrap = create(:user, account:, email: claims.fetch('email'))
+    allow(MaiocchiSso::Configuration).to receive(:bootstrap_user_uuid).and_return(bootstrap.uuid)
+
+    expect(described_class.call(claims, now:)).to eq(bootstrap)
+    expect(bootstrap.reload.maiocchi_sso_identity.subject).to eq(claims.fetch('subject'))
+  end
+
+  it 'rejects bootstrap email mismatch and an identity bound to another account' do
+    bootstrap = create(:user, account:, email: 'outro@maiocchi.adv.br')
+    allow(MaiocchiSso::Configuration).to receive(:bootstrap_user_uuid).and_return(bootstrap.uuid)
+    expect { described_class.call(claims, now:) }.to raise_error(MaiocchiSso::FlowError)
+
+    other_account = create(:account)
+    other_user = create(:user, account: other_account, email: claims.fetch('email'))
+    create_identity(other_user, other_account)
+    allow(MaiocchiSso::Configuration).to receive(:bootstrap_user_uuid).and_return(nil)
+    expect { described_class.call(claims.merge('exchange_id' => SecureRandom.uuid), now:) }
+      .to raise_error(MaiocchiSso::FlowError)
+  end
+
+  it 'rejects non-staff role and archived allowlisted account' do
+    expect { described_class.call(claims.merge('role' => 'cliente'), now:) }
+      .to raise_error(MaiocchiSso::FlowError)
+
+    account.update!(archived_at: now)
+    expect { described_class.call(claims.merge('exchange_id' => SecureRandom.uuid), now:) }
+      .to raise_error(MaiocchiSso::FlowError)
+  end
+
+  private
+
+  def create_identity(identity_user, identity_account)
+    MaiocchiSsoIdentity.create!(
+      account: identity_account,
+      user: identity_user,
+      provider: MaiocchiSso::Configuration::PROVIDER,
+      subject: claims.fetch('subject'),
+      email_at_link: claims.fetch('email'),
+      external_role: 'advogado',
+      last_authenticated_at: now
+    )
+  end
+end
diff --git a/spec/lib/maiocchi_sso_token_exchange_spec.rb b/spec/lib/maiocchi_sso_token_exchange_spec.rb
new file mode 100644
index 0000000000000000000000000000000000000000..17dcfeb3c6d8268fa1737ab97dd2b755a661f889
--- /dev/null
+++ b/spec/lib/maiocchi_sso_token_exchange_spec.rb
@@ -0,0 +1,108 @@
+# frozen_string_literal: true
+
+RSpec.describe MaiocchiSso::TokenExchange do
+  let(:secret) { 's' * 48 }
+  let(:nonce) { 'n' * 43 }
+  let(:code) { 'c' * 43 }
+  let(:verifier) { 'v' * 64 }
+  let(:now) { Time.utc(2026, 7, 18, 12) }
+  let(:claims) do
+    {
+      'ok' => true,
+      'token_type' => MaiocchiSso::Configuration::TOKEN_TYPE,
+      'expires_in' => 30,
+      'issued_at' => now.iso8601,
+      'expires_at' => (now + 30.seconds).iso8601,
+      'issuer' => MaiocchiSso::Configuration::ISSUER,
+      'audience' => MaiocchiSso::Configuration::AUDIENCE,
+      'scope' => MaiocchiSso::Configuration::SCOPE,
+      'nonce' => nonce,
+      'subject' => 'f3065564-0e72-480f-bd82-60d951ab909b',
+      'email' => 'advogado@maiocchi.adv.br',
+      'name' => 'Advogado Maiocchi',
+      'role' => 'advogado',
+      'auth_time' => now.iso8601,
+      'exchange_id' => 'ef1961c8-ecc9-426c-92bb-7d87994f2883'
+    }
+  end
+
+  before do
+    allow(MaiocchiSso::Configuration).to receive(:validate!).and_return(true)
+    allow(MaiocchiSso::Configuration).to receive(:client_secret).and_return(secret)
+  end
+
+  it 'uses exact HTTPS backchannel, distinct Basic credential, PKCE verifier and nonce' do
+    request = stub_request(:post, MaiocchiSso::Configuration::TOKEN_URL)
+      .with do |incoming|
+        body = Rack::Utils.parse_query(incoming.body)
+        incoming.headers['Authorization'] ==
+          "Basic #{Base64.strict_encode64("#{MaiocchiSso::Configuration::CLIENT_ID}:#{secret}")}" &&
+          body == {
+            'grant_type' => 'authorization_code',
+            'code' => code,
+            'redirect_uri' => MaiocchiSso::Configuration::REDIRECT_URI,
+            'code_verifier' => verifier,
+            'nonce' => nonce
+          }
+      end
+      .to_return(status: 200, headers: { 'Content-Type' => 'application/json' }, body: claims.to_json)
+
+    result = described_class.call(code:, verifier:, nonce:, now:)
+
+    expect(result).to eq(claims)
+    expect(request).to have_been_requested.once
+  end
+
+  it 'fails closed for nonce, issuer, audience, scope, role and expiry divergence' do
+    mutations = [
+      { 'nonce' => 'x' * 43 },
+      { 'issuer' => 'https://evil.invalid' },
+      { 'audience' => 'outro' },
+      { 'scope' => 'openid' },
+      { 'role' => 'cliente' },
+      { 'expires_in' => 0 },
+      { 'expires_in' => 31 },
+      { 'issued_at' => (now - 31.seconds).iso8601 },
+      { 'expires_at' => (now - 1.second).iso8601 }
+    ]
+
+    mutations.each do |mutation|
+      stub_request(:post, MaiocchiSso::Configuration::TOKEN_URL)
+        .to_return(status: 200, headers: { 'Content-Type' => 'application/json' },
+                   body: claims.merge(mutation).to_json)
+
+      expect { described_class.call(code:, verifier:, nonce:, now:) }
+        .to raise_error(MaiocchiSso::FlowError)
+      WebMock.reset!
+    end
+  end
+
+  it 'rejects provider-side PKCE failure, malformed fields, extra claims and oversized responses' do
+    responses = [
+      { status: 400, headers: { 'Content-Type' => 'application/json' }, body: '{"error":"invalid_grant"}' },
+      { status: 200, headers: { 'Content-Type' => 'application/json' }, body: claims.merge('subject' => 'not-a-uuid').to_json },
+      { status: 200, headers: { 'Content-Type' => 'application/json' }, body: claims.merge('unexpected' => true).to_json },
+      { status: 200, headers: { 'Content-Type' => 'application/json', 'Content-Length' => '40000' }, body: claims.to_json },
+      { status: 200, headers: { 'Content-Type' => 'application/json' }, body: 'x' * (32.kilobytes + 1) }
+    ]
+
+    responses.each do |response|
+      stub_request(:post, MaiocchiSso::Configuration::TOKEN_URL).to_return(**response)
+      expect { described_class.call(code:, verifier:, nonce:, now:) }
+        .to raise_error(MaiocchiSso::FlowError)
+      WebMock.reset!
+    end
+  end
+
+  it 'rejects an expired/future authentication context' do
