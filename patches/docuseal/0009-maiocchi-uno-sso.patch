+# frozen_string_literal: true
+
+require 'uri'
+
+RSpec.describe 'Maiocchi SSO' do
+  let(:app_host) { 'assinatura.maiocchi.adv.br' }
+  let(:user) { create(:user) }
+  let(:claims) do
+    {
+      'subject' => SecureRandom.uuid,
+      'email' => user.email,
+      'role' => 'advogado',
+      'exchange_id' => SecureRandom.uuid
+    }
+  end
+
+  before do
+    host! app_host
+    https!
+    allow(MaiocchiSso::Configuration).to receive(:validate!).and_return(true)
+    allow(MaiocchiSso::Configuration).to receive(:callback_host).and_return(app_host)
+    allow(MaiocchiSso::IdentityResolver).to receive(:call).and_return(user)
+  end
+
+  it 'creates state, nonce and PKCE S256, then rotates into a local DocuSeal session' do
+    get maiocchi_sso_start_path
+
+    expect(response).to have_http_status(:see_other)
+    authorize_uri = URI.parse(response.location)
+    query = Rack::Utils.parse_query(authorize_uri.query)
+    expect(authorize_uri.to_s).to start_with(MaiocchiSso::Configuration::AUTHORIZE_URL)
+    expect(query).to include(
+      'response_type' => 'code',
+      'client_id' => MaiocchiSso::Configuration::CLIENT_ID,
+      'redirect_uri' => MaiocchiSso::Configuration::REDIRECT_URI,
+      'code_challenge_method' => 'S256',
+      'scope' => MaiocchiSso::Configuration::SCOPE,
+      'audience' => MaiocchiSso::Configuration::AUDIENCE
+    )
+    expect(query.fetch('state')).to match(/\A[A-Za-z0-9_-]{43}\z/)
+    expect(query.fetch('nonce')).to match(/\A[A-Za-z0-9_-]{43}\z/)
+    expect(query.fetch('code_challenge')).to match(/\A[A-Za-z0-9_-]{43}\z/)
+
+    captured = nil
+    allow(MaiocchiSso::TokenExchange).to receive(:call) do |**input|
+      captured = input
+      claims
+    end
+
+    get maiocchi_sso_callback_path, params: { code: 'c' * 43, state: query.fetch('state') }
+
+    expect(response).to redirect_to(dashboard_index_path)
+    expect(captured.fetch(:nonce)).to eq(query.fetch('nonce'))
+    expected_challenge = Base64.urlsafe_encode64(Digest::SHA256.digest(captured.fetch(:verifier)), padding: false)
+    expect(expected_challenge).to eq(query.fetch('code_challenge'))
+    expect(controller.current_user).to eq(user)
+    expect(response.headers['Cache-Control'].split(',').map(&:strip)).to include('no-store')
+    expect(response.headers['Referrer-Policy']).to eq('no-referrer')
+  end
+
+  it 'consumes the browser state on first callback and rejects replay' do
+    get maiocchi_sso_start_path
+    state = Rack::Utils.parse_query(URI.parse(response.location).query).fetch('state')
+    allow(MaiocchiSso::TokenExchange).to receive(:call).and_return(claims)
+
+    get maiocchi_sso_callback_path, params: { code: 'c' * 43, state: }
+    expect(response).to redirect_to(dashboard_index_path)
+
+    get maiocchi_sso_callback_path, params: { code: 'c' * 43, state: }
+    expect(response).to have_http_status(:unprocessable_content)
+    expect(MaiocchiSso::TokenExchange).to have_received(:call).once
+  end
+
+  it 'rejects a wrong state without calling the backchannel' do
+    get maiocchi_sso_start_path
+    allow(MaiocchiSso::TokenExchange).to receive(:call)
+
+    get maiocchi_sso_callback_path, params: { code: 'c' * 43, state: 'x' * 43 }
+
+    expect(response).to have_http_status(:unprocessable_content)
+    expect(MaiocchiSso::TokenExchange).not_to have_received(:call)
+    expect(response.headers['Cache-Control'].split(',').map(&:strip)).to include('no-store')
+    expect(response.headers['Pragma']).to eq('no-cache')
+    expect(response.headers['Referrer-Policy']).to eq('no-referrer')
+  end
+
+  it 'rejects an expired browser flow before exchanging the code' do
+    travel_to Time.utc(2026, 7, 18, 12) do
+      get maiocchi_sso_start_path
+      @state = Rack::Utils.parse_query(URI.parse(response.location).query).fetch('state')
+    end
+    allow(MaiocchiSso::TokenExchange).to receive(:call)
+
+    travel_to Time.utc(2026, 7, 18, 12, 6) do
+      get maiocchi_sso_callback_path, params: { code: 'c' * 43, state: @state }
+    end
+
+    expect(response).to have_http_status(:unprocessable_content)
+    expect(MaiocchiSso::TokenExchange).not_to have_received(:call)
+  end
+
+  it 'rejects extra callback parameters and a non-canonical host' do
+    get maiocchi_sso_start_path
+    state = Rack::Utils.parse_query(URI.parse(response.location).query).fetch('state')
+
+    get maiocchi_sso_callback_path, params: { code: 'c' * 43, state:, extra: '1' }
+    expect(response).to have_http_status(:unprocessable_content)
+
+    host! 'assinatura.maiocchi.adv.br.evil.invalid'
+    get maiocchi_sso_start_path
+    expect(response).to have_http_status(:unprocessable_content)
+    expect(response.headers['Cache-Control'].split(',').map(&:strip)).to include('no-store')
+    expect(response.headers['Pragma']).to eq('no-cache')
+    expect(response.headers['Referrer-Policy']).to eq('no-referrer')
+  end
+end
