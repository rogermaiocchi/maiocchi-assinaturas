diff --git a/spec/requests/submitter_signature_modes_spec.rb b/spec/requests/submitter_signature_modes_spec.rb
new file mode 100644
index 0000000000000000000000000000000000000000..78b3ca1bc147a47cc7c1fcc4b0f11b4e7ee5b408
--- /dev/null
+++ b/spec/requests/submitter_signature_modes_spec.rb
@@ -0,0 +1,69 @@
+# frozen_string_literal: true
+
+RSpec.describe 'Submitter signature modes' do
+  let(:user) { create(:user) }
+  let(:template) { create(:template, account: user.account, author: user) }
+  let(:submission) { create(:submission, template:, account: user.account, created_by_user: user) }
+  let(:submitter) { create(:submitter, submission:, uuid: template.submitters.first['uuid']) }
+
+  before do
+    allow(PrivatePadesTickets).to receive(:remote_available?).and_return(false)
+  end
+
+  it 'offers all three modes to a client holding the signer link' do
+    get submit_form_signature_mode_path(submitter.slug)
+
+    expect(response).to have_http_status(:ok)
+    expect(response.body).to include('Eletrônica simples')
+    expect(response.body).to include('Eletrônica avançada')
+    expect(response.body).to include('Digital qualificada')
+  end
+
+  it 'selects advanced mode and enables email verification for that signer' do
+    patch submit_form_signature_mode_path(submitter.slug),
+          params: { signature_mode: MaiocchiSignaturePolicy::ADVANCED }
+
+    expect(response).to redirect_to(submit_form_path(submitter.slug))
+    expect(submitter.reload.signature_mode).to eq(MaiocchiSignaturePolicy::ADVANCED)
+    expect(submitter.preferences['require_email_2fa']).to be(true)
+    expect(submitter.submission_events.last.event_type).to eq('select_signature_mode')
+  end
+
+  it 'routes qualified mode to the protected PDF preparation page' do
+    patch submit_form_signature_mode_path(submitter.slug),
+          params: { signature_mode: MaiocchiSignaturePolicy::QUALIFIED }
+
+    expect(response).to redirect_to(new_qualified_signature_path(submitter_slug: submitter.slug))
+    expect(submitter.reload.signature_mode).to eq(MaiocchiSignaturePolicy::QUALIFIED)
+  end
+
+  it 'rejects an unknown mode without changing the signer policy' do
+    original = submitter.signature_mode
+
+    patch submit_form_signature_mode_path(submitter.slug), params: { signature_mode: 'pretend-qualified' }
+
+    expect(response).to redirect_to(submit_form_signature_mode_path(submitter.slug))
+    expect(submitter.reload.signature_mode).to eq(original)
+  end
+
+  it 'keeps every mode visible but blocks a downgrade below the required level' do
+    template.update!(preferences: template.preferences.merge('signature_mode' => MaiocchiSignaturePolicy::ADVANCED))
+    required_submitter = create(:submitter, submission:, uuid: SecureRandom.uuid)
+    two_factor_token = Submitter.signed_id_verifier.generate(
+      required_submitter.slug,
+      purpose: :email_two_factor
+    )
+
+    get submit_form_signature_mode_path(required_submitter.slug)
+    expect(response.body).to include('Eletrônica simples')
+    expect(response.body).to include('Não atende à exigência mínima AVANÇADA')
+
+    patch submit_form_signature_mode_path(required_submitter.slug),
+          params: {
+            signature_mode: MaiocchiSignaturePolicy::SIMPLE,
+            two_factor_token:
+          }
+    expect(response).to redirect_to(submit_form_signature_mode_path(required_submitter.slug))
+    expect(required_submitter.reload.signature_mode).to eq(MaiocchiSignaturePolicy::ADVANCED)
+  end
+end
