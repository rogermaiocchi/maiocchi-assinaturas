diff --git a/lib/qualified_signatures/canonical_source.rb b/lib/qualified_signatures/canonical_source.rb
new file mode 100644
index 0000000000000000000000000000000000000000..fdc7812641307c96ce0c6ce831771e96ae668db8
--- /dev/null
+++ b/lib/qualified_signatures/canonical_source.rb
@@ -0,0 +1,60 @@
+# frozen_string_literal: true
+
+module QualifiedSignatures
+  module CanonicalSource
+    module_function
+
+    def call(submitter, request)
+      if submitter.name.blank?
+        raise PrivatePadesTickets::Error,
+              'Informe o nome completo do signatário antes de usar o certificado digital.'
+      end
+
+      ensure_signing_order!(submitter)
+
+      submitter.with_lock do
+        finalize_values_without_completion!(submitter, request)
+        attachment = canonical_attachment(submitter)
+        pdf = attachment.download
+        PrivatePadesTickets.validate_pdf!(pdf)
+        [pdf, attachment.filename.to_s]
+      end
+    rescue Submitters::SubmitValues::RequiredFieldError
+      raise PrivatePadesTickets::Error,
+            'Preencha todos os campos obrigatórios do documento antes de iniciar a assinatura com certificado digital.'
+    end
+
+    def ensure_signing_order!(submitter)
+      others = submitter.submission.submitters.where.not(id: submitter.id)
+      if others.exists?(completed_at: nil)
+        raise PrivatePadesTickets::Error,
+              'As assinaturas eletrônicas anteriores devem ser concluídas antes da assinatura ICP-Brasil final.'
+      end
+      return unless others.exists?(signature_mode: MaiocchiSignaturePolicy::QUALIFIED)
+
+      raise PrivatePadesTickets::Error,
+            'A coassinatura PAdES incremental ainda não está habilitada para mais de um certificado no mesmo documento.'
+    end
+
+    def finalize_values_without_completion!(submitter, request)
+      Submitters::SubmitValues.assign_completed_attributes(submitter, request)
+      submitter.completed_at = nil
+      submitter.save!
+    end
+
+    def canonical_attachment(submitter)
+      submission = submitter.submission
+      values_hash = Submissions::GeneratePreviewAttachments.build_submitter_values_hash(submitter)
+      current = submission.preview_merged_document_attachment
+      return current if current&.metadata&.dig('values_hash') == values_hash
+
+      ApplicationRecord.no_touching { current&.destroy }
+      Submissions::GeneratePreviewAttachments.call(
+        submission,
+        values_hash:,
+        submitter:,
+        merge: true
+      ).first
+    end
+  end
+end
diff --git a/lib/qualified_signatures/commit.rb b/lib/qualified_signatures/commit.rb
new file mode 100644
index 0000000000000000000000000000000000000000..691a4b496374fbf1db05af3e38e67f2a93520bdd
--- /dev/null
+++ b/lib/qualified_signatures/commit.rb
@@ -0,0 +1,138 @@
+# frozen_string_literal: true
+
+require 'base64'
+require 'digest'
+
+module QualifiedSignatures
+  module Commit
+    Error = Class.new(StandardError)
+    HASH_PATTERN = /\A[a-f0-9]{64}\z/
+
+    module_function
+
+    def call(ticket:, request:)
+      response = PrivatePadesTickets.commit(ticket:)
+      receipt = response.fetch('receipt')
+      submitter = load_submitter!(receipt)
+      pdf = decode_pdf!(response.fetch('signedPdfBase64'), receipt)
+      committed = false
+
+      submitter.with_lock do
+        return submitter if already_committed?(submitter, receipt)
+
+        validate_receipt!(submitter, receipt, pdf)
+        attach_signed_pdf!(submitter, pdf, receipt)
+        mark_committed!(submitter, receipt, request)
+        committed = true
+      end
+
+      ProcessSubmitterCompletionJob.perform_async('submitter_id' => submitter.id) if committed
+      submitter
+    rescue KeyError, ArgumentError, JSON::ParserError => e
+      raise Error, "O comprovante qualificado está incompleto (#{e.class.name})."
+    end
+
+    def load_submitter!(receipt)
+      origin = receipt.fetch('origin')
+      raise Error, 'O resultado não pertence ao fluxo documental do portal.' unless origin['system'] == 'docuseal'
+
+      Submitter.find_by!(qualified_signature_public_id: receipt.fetch('publicId'))
+    rescue ActiveRecord::RecordNotFound
+      raise Error, 'O signatário vinculado ao resultado não foi localizado.'
+    end
+
+    def decode_pdf!(encoded, receipt)
+      pdf = Base64.strict_decode64(encoded)
+      digest = Digest::SHA256.hexdigest(pdf)
+      expected = receipt.dig('hashes', 'signedPdfSha256')
+      unless digest == expected && pdf.start_with?('%PDF-')
+        raise Error,
+              'O PDF devolvido não corresponde ao hash validado.'
+      end
+
+      pdf
+    end
+
+    def validate_receipt!(submitter, receipt, pdf)
+      origin = receipt.fetch('origin')
+      hashes = receipt.fetch('hashes')
+      validation = receipt.fetch('validation')
+      signer = receipt.fetch('signer')
+
+      checks = [
+        receipt['version'] == 1,
+        origin['submissionReference'] == MaiocchiSignaturePolicy.public_id(submitter.submission),
+        origin['submitterUuid'] == submitter.uuid,
+        submitter.signature_mode == MaiocchiSignaturePolicy::QUALIFIED,
+        submitter.qualified_signature_state == 'ticketed',
+        submitter.qualified_signature_public_id == receipt['publicId'],
+        submitter.qualified_signature_source_sha256 == hashes['sourcePdfSha256'],
+        hashes['sourcePdfSha256'].to_s.match?(HASH_PATTERN),
+        hashes['signedPdfSha256'].to_s.match?(HASH_PATTERN),
+        Digest::SHA256.hexdigest(pdf) == hashes['signedPdfSha256'],
+        signer['identityMatch'] == true,
+        signer['certificateFingerprintSha256'].to_s.match?(HASH_PATTERN),
+        validation['status'] == 'valid',
+        validation['signatureCount'].to_i.positive?,
+        receipt.dig('proof', 'algorithm') == 'ML-DSA-65'
+      ]
+      raise Error, 'O PAdES não passou pelo vínculo integral com documento, signatário e validação.' unless checks.all?
+    end
+
+    def already_committed?(submitter, receipt)
+      return false unless submitter.qualified_signature_state == 'committed'
+
+      same_result = submitter.qualified_signature_public_id == receipt['publicId'] &&
+                    submitter.qualified_signature_signed_sha256 == receipt.dig('hashes', 'signedPdfSha256')
+      return true if same_result
+
+      raise Error, 'Já existe outro resultado qualificado confirmado para este signatário.'
+    end
+
+    def attach_signed_pdf!(submitter, pdf, receipt)
+      filename = receipt.fetch('documentName').sub(/\.pdf\z/i, '-assinado.pdf')
+      sha256 = receipt.dig('hashes', 'signedPdfSha256')
+      blob = ActiveStorage::Blob.create_and_upload!(
+        io: StringIO.new(pdf),
+        filename:,
+        content_type: 'application/pdf',
+        metadata: {
+          'sha256' => sha256,
+          'evidence_id' => receipt.fetch('publicId'),
+          'signature_mode' => MaiocchiSignaturePolicy::QUALIFIED,
+          'document_number' => receipt.fetch('documentNumber')
+        }
+      )
+      ActiveStorage::Attachment.create!(blob:, name: 'documents', record: submitter)
+    end
+
+    def mark_committed!(submitter, receipt, request)
+      completed_at = Time.iso8601(receipt.fetch('completedAt'))
+      submitter.assign_attributes(
+        qualified_signature_state: 'committed',
+        qualified_signature_signed_sha256: receipt.dig('hashes', 'signedPdfSha256'),
+        qualified_signature_receipt: receipt,
+        qualified_signature_completed_at: completed_at,
+        completed_at:,
+        ip: request.remote_ip,
+        ua: request.user_agent,
+        timezone: request.params[:timezone].presence || submitter.timezone
+      )
+      submitter.save!
+      LockEvent.find_or_create_by!(key: "result_attachments:#{submitter.id}", event_name: :complete)
+      create_completion_event!(submitter, 'complete_qualified_signature', request, receipt)
+      create_completion_event!(submitter, 'complete_form', request, receipt)
+    end
+
+    def create_completion_event!(submitter, type, request, receipt)
+      return if submitter.submission_events.exists?(event_type: type)
+
+      SubmissionEvents.create_with_tracking_data(
+        submitter,
+        type,
+        request,
+        { public_id: receipt.fetch('publicId'), signed_pdf_sha256: receipt.dig('hashes', 'signedPdfSha256') }
+      )
+    end
+  end
+end
