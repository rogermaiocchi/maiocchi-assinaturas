+      submitter.preferences['require_email_2fa'] = true
+    else
+      submitter.preferences.delete('require_email_2fa')
+    end
+    clear_uncommitted_qualified_attempt!(submitter) if normalized != QUALIFIED
+    submitter.save! if save
