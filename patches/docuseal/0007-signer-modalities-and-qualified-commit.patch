+    end
+
+    apply_to_submitter!(submitter, required_mode_for(submitter), source: source, save: save)
+  end
+
   def apply_to_submission!(submission)
     submission.preferences ||= {}
     submission.preferences['signature_mode'] = mode_for(submission)
