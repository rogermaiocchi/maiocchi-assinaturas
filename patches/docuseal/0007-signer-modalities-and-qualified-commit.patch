--- /dev/null
+++ b/app/views/submitter_signature_modes/show.html.erb
@@ -0,0 +1,52 @@
+<% content_for(:html_title, "Modalidade de assinatura | #{MaiocchiBrand::PRODUCT_NAME}") %>
+<main class="maiocchi-mode-picker">
+  <header class="maiocchi-mode-picker__header">
+    <a href="<%= submit_form_path(@submitter.slug) %>" class="maiocchi-signing-brand" aria-label="Voltar ao documento">
+      <%= render 'shared/logo', width: '54px', height: '54px' %>
+    </a>
+    <div>
+      <p class="maiocchi-eyebrow">IDENTIFICAÇÃO DO SIGNATÁRIO</p>
+      <h1>Como deseja assinar?</h1>
+      <p>Escolha a modalidade para <strong><%= @submitter.submission.name || @submitter.submission.template.name %></strong>. A opção pode ser alterada enquanto o documento não for concluído.</p>
+    </div>
+  </header>
+
+  <section class="maiocchi-modes" aria-label="Modalidades disponíveis">
+    <div class="maiocchi-modes__grid">
+      <% [
+        [MaiocchiSignaturePolicy::SIMPLE, 'writing_sign', 'Eletrônica simples', 'Manifestação eletrônica com identidade, IP, dispositivo, data, hora, hash e trilha de auditoria.'],
+        [MaiocchiSignaturePolicy::ADVANCED, 'email_check', 'Eletrônica avançada', 'Confirmação adicional por código enviado ao e-mail do signatário e trilha probatória.'],
+        [MaiocchiSignaturePolicy::QUALIFIED, 'certificate', 'Digital qualificada', 'PAdES com certificado ICP-Brasil autorizado pelo titular em token físico ou, quando integrado, em PSC remoto.']
+      ].each do |mode, icon, title, description| %>
+        <% current = @current_mode == mode %>
+        <% allowed = MaiocchiSignaturePolicy.allowed_modes_for(@submitter).include?(mode) %>
+        <article class="maiocchi-mode-card <%= 'maiocchi-mode-card--qualified' if mode == MaiocchiSignaturePolicy::QUALIFIED %> <%= 'is-current' if current %>">
+          <span class="maiocchi-mode-icon" aria-hidden="true"><%= svg_icon(icon, class: 'w-7 h-7') %></span>
+          <div class="maiocchi-mode-card__copy">
+            <h2><%= title %></h2>
+            <p><%= description %></p>
+            <small><%= MaiocchiSignaturePolicy::MODES.dig(mode, :legal_basis) %></small>
+          </div>
+          <% if allowed %>
+            <%= button_to submit_form_signature_mode_path(@submitter.slug), method: :patch,
+                          params: { signature_mode: mode },
+                          class: 'maiocchi-icon-action', form_class: 'maiocchi-mode-card__action' do %>
+              <%= svg_icon(current ? 'check' : (mode == MaiocchiSignaturePolicy::QUALIFIED ? 'certificate' : 'arrow_right'), class: 'w-5 h-5') %>
+              <span><%= current ? 'Modalidade atual' : (mode == MaiocchiSignaturePolicy::QUALIFIED ? 'Usar certificado digital' : 'Escolher modalidade') %></span>
+            <% end %>
+          <% else %>
+            <p class="maiocchi-mode-card__status">Não atende à exigência mínima <%= MaiocchiSignaturePolicy::MODES.dig(@required_mode, :label) %> deste documento.</p>
+          <% end %>
+          <% if mode == MaiocchiSignaturePolicy::QUALIFIED && !@remote_available %>
+            <p class="maiocchi-mode-card__status">Token físico disponível pelo agente local. PSC remoto ainda não conectado.</p>
+          <% end %>
+        </article>
+      <% end %>
+    </div>
+  </section>
+
+  <a href="<%= submit_form_path(@submitter.slug) %>" class="maiocchi-mode-picker__back">
+    <%= svg_icon('arrow_left', class: 'w-5 h-5') %>
+    <span>Voltar ao documento</span>
+  </a>
+</main>
