@@ -0,0 +1,102 @@
+# frozen_string_literal: true
+
+RSpec.describe 'Qualified signature completion' do
+  let(:user) { create(:user) }
+  let(:template) { create(:template, account: user.account, author: user) }
+  let(:submission) { create(:submission, template:, account: user.account, created_by_user: user) }
+  let(:submitter) do
+    create(:submitter, submission:, uuid: template.submitters.first['uuid'], name: 'Cliente Identificado')
+  end
+  let(:ticket) { 'A' * 43 }
+  let(:source_sha256) { 'a' * 64 }
+  let(:signed_pdf) { Rails.root.join('spec/fixtures/sample-document.pdf').binread }
+  let(:signed_sha256) { Digest::SHA256.hexdigest(signed_pdf) }
+  let(:public_id) { 'MAI-2026-1111-2222-3333-4444' }
+  let(:receipt) do
+    {
+      'version' => 1,
+      'publicId' => public_id,
+      'documentNumber' => '20260715103000000000000000001',
+      'documentName' => 'documento-canonico.pdf',
+      'origin' => {
+        'system' => 'docuseal',
+        'submissionReference' => MaiocchiSignaturePolicy.public_id(submission),
+        'submitterUuid' => submitter.uuid
+      },
+      'hashes' => {
+        'sourcePdfSha256' => source_sha256,
+        'presentationPdfSha256' => 'b' * 64,
+        'signedPdfSha256' => signed_sha256,
+        'validationReportSha256' => 'c' * 64
+      },
+      'signer' => {
+        'name' => submitter.name,
+        'nationalIdMasked' => '006.***.***-40',
+        'certificateFingerprintSha256' => 'd' * 64,
+        'identityMatch' => true
+      },
+      'validation' => { 'status' => 'valid', 'policyOid' => '2.16.76.1.7.1.11.1.3', 'signatureCount' => 1 },
+      'proof' => { 'algorithm' => 'ML-DSA-65', 'value' => 'proof' },
+      'completedAt' => Time.current.utc.iso8601
+    }
+  end
+
+  before do
+    MaiocchiSignaturePolicy.apply_to_submitter!(submitter, MaiocchiSignaturePolicy::QUALIFIED)
+    submitter.update!(
+      qualified_signature_state: 'ticketed',
+      qualified_signature_public_id: public_id,
+      qualified_signature_source_sha256: source_sha256
+    )
+    allow(PrivatePadesTickets).to receive(:commit).and_return(
+      'signedPdfBase64' => Base64.strict_encode64(signed_pdf),
+      'receipt' => receipt
+    )
+  end
+
+  it 'atomically attaches the validated PAdES before completing the signer' do
+    post complete_qualified_signature_path, params: { ticket: }, as: :json
+
+    expect(response).to have_http_status(:ok)
+    expect(submitter.reload).to have_attributes(
+      completed_at: be_present,
+      qualified_signature_state: 'committed',
+      qualified_signature_signed_sha256: signed_sha256
+    )
+    expect(submitter.documents.count).to eq(1)
+    expect(Digest::SHA256.hexdigest(submitter.documents.first.download)).to eq(signed_sha256)
+    expect(submitter.submission_events.where(event_type: 'complete_qualified_signature').count).to eq(1)
+    expect(submitter.submission_events.where(event_type: 'complete_form').count).to eq(1)
+  end
+
+  it 'selects the ticketed signer when a reused template has the same role UUID' do
+    older_submission = create(:submission, template:, account: user.account, created_by_user: user)
+    older_submitter = create(:submitter, submission: older_submission, uuid: submitter.uuid,
+                                         name: submitter.name)
+
+    post complete_qualified_signature_path, params: { ticket: }, as: :json
+
+    expect(response).to have_http_status(:ok)
+    expect(submitter.reload.qualified_signature_state).to eq('committed')
+    expect(older_submitter.reload.completed_at).to be_nil
+    expect(older_submitter.documents).to be_empty
+  end
+
+  it 'is idempotent when the same validated result is reconciled twice' do
+    2.times { post complete_qualified_signature_path, params: { ticket: }, as: :json }
+
+    expect(response).to have_http_status(:ok)
+    expect(submitter.reload.documents.count).to eq(1)
+    expect(submitter.submission_events.where(event_type: 'complete_qualified_signature').count).to eq(1)
+  end
+
+  it 'rejects an identity mismatch without completing or attaching a document' do
+    receipt['signer']['identityMatch'] = false
+
+    post complete_qualified_signature_path, params: { ticket: }, as: :json
+
+    expect(response).to have_http_status(:unprocessable_content)
+    expect(submitter.reload.completed_at).to be_nil
+    expect(submitter.documents).to be_empty
+  end
+end
