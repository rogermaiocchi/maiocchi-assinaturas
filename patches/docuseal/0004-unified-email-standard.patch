diff --git a/spec/lib/image_utils_spec.rb b/spec/lib/image_utils_spec.rb
new file mode 100644
index 0000000..b796b80
--- /dev/null
+++ b/spec/lib/image_utils_spec.rb
@@ -0,0 +1,20 @@
+# frozen_string_literal: true
+
+RSpec.describe ImageUtils do
+  it 'loads an allowed image from its detected content type' do
+    data = Rails.root.join('spec/fixtures/sample-image.png').binread
+
+    image = described_class.load_vips(data, content_type: 'application/octet-stream')
+
+    expect(image.width).to be_positive
+    expect(image.height).to be_positive
+  end
+
+  it 'rejects TIFF input even when the declared content type is allowed' do
+    tiff_header = "II*\x00\x08\x00\x00\x00".b
+
+    expect do
+      described_class.load_vips(tiff_header, content_type: 'image/jpeg')
+    end.to raise_error(Vips::Error, /Formato de imagem não permitido: image\/tiff/)
+  end
+end
diff --git a/spec/mailers/maiocchi_email_standard_spec.rb b/spec/mailers/maiocchi_email_standard_spec.rb
new file mode 100644
index 0000000..4c2c01a
--- /dev/null
+++ b/spec/mailers/maiocchi_email_standard_spec.rb
@@ -0,0 +1,83 @@
+# frozen_string_literal: true
+
+RSpec.describe 'Maiocchi email standard' do
+  let(:message) { SettingsMailer.smtp_successful_setup(MaiocchiBrand::SUPPORT_EMAIL).message }
+  let(:html) { message.body.decoded }
+
+  it 'uses the canonical sender and reply address' do
+    expect(message.from).to eq([MaiocchiBrand::SUPPORT_EMAIL])
+    expect(message.reply_to).to eq([MaiocchiBrand::SUPPORT_EMAIL])
+  end
+
+  it 'renders the unified visual and textual contract exactly once' do
+    expect(html.scan('data-maiocchi-email-standard="1"').size).to eq(1)
+    expect(html.scan('data-email-salutation="1"').size).to eq(1)
+    expect(html.scan('data-email-signature="1"').size).to eq(1)
+    expect(html.scan('data-automatic-email-notice="1"').size).to eq(1)
+    expect(html).to include('border-top:3pt solid #ffc400')
+    expect(html).to include('padding:1pt')
+    expect(html).to include('aria-label="Mensagem automática"')
+    expect(html).to include(MaiocchiBrand::EMAIL_SALUTATION)
+    expect(html).to include('Respeitosamente,')
+    expect(html).to include(MaiocchiBrand::LAWYER_SIGNATURE)
+    expect(html).to include(MaiocchiBrand::AUTOMATED_EMAIL_NOTICE)
+  end
+
+  it 'does not expose source links or attach documents' do
+    expect(html).not_to include('github.com')
+    expect(html).not_to include('Fonte correspondente')
+    expect(message.attachments).to be_empty
+    expect(MaiocchiBrand::EMAIL_ATTACHMENTS_ENABLED).to be(false)
+  end
+
+  it 'generates a text alternative with the same closing and automated notice' do
+    HtmlToPlainTextInterceptor.process(message)
+
+    text = message.text_part.decoded
+    normalized_text = text.gsub(/\s+/, ' ').strip
+
+    expect(text).to start_with(MaiocchiBrand::EMAIL_SALUTATION)
+    expect(text).not_to include('body {')
+    expect(text).not_to include('.maiocchi-content')
+    expect(normalized_text).to include('Respeitosamente,')
+    expect(normalized_text).to include(MaiocchiBrand::LAWYER_SIGNATURE)
+    expect(normalized_text).to include(MaiocchiBrand::AUTOMATED_EMAIL_NOTICE)
+  end
+
+  it 'forces canonical headers over legacy values' do
+    legacy = Mail.new(from: 'legacy@example.com', reply_to: 'legacy@example.com')
+
+    ActionMailerConfigsInterceptor.enforce_maiocchi_headers(legacy)
+
+    expect(legacy.from).to eq([MaiocchiBrand::SUPPORT_EMAIL])
+    expect(legacy.reply_to).to eq([MaiocchiBrand::SUPPORT_EMAIL])
+  end
+
+  it 'keeps stock templates free of duplicate greetings, closings and reply requests' do
+    templates = %w[
+      app/views/devise/mailer/reset_password_instructions.html.erb
+      app/views/settings_mailer/smtp_successful_setup.html.erb
+      app/views/submitter_mailer/completed_email.html.erb
+      app/views/submitter_mailer/declined_email.html.erb
+      app/views/submitter_mailer/documents_copy_email.html.erb
+      app/views/submitter_mailer/invitation_email.html.erb
+      app/views/submitter_mailer/otp_verification_email.html.erb
+      app/views/template_mailer/otp_verification_email.html.erb
+      app/views/user_mailer/invitation_email.html.erb
+    ]
+
+    templates.each do |template|
+      source = Rails.root.join(template).read
+
+      expect(source).not_to match(/hi_there|hello_name|t\(['"]thanks['"]\)|replying_to_this_email/)
+      expect(source).not_to include('Respeitosamente,')
+      expect(source).not_to include(MaiocchiBrand::LAWYER_SIGNATURE)
+    end
+  end
+
+  it 'blocks attachment generation even when an old preference requests it' do
+    mailer = SubmitterMailer.new
+
+    expect(mailer.send(:add_completed_email_attachments!, nil)).to eq([])
+  end
+end
