diff --git a/app/services/maiocchi_uno_certificate_join.rb b/app/services/maiocchi_uno_certificate_join.rb
new file mode 100644
index 0000000..1de0c80
--- /dev/null
+++ b/app/services/maiocchi_uno_certificate_join.rb
@@ -0,0 +1,77 @@
+# frozen_string_literal: true
+
+require 'net/http'
+require 'json'
+require 'uri'
+
+# Cliente HTTP: DocuSeal → API UNO POST /v1/auth/certificate/join-code
+module MaiocchiUnoCertificateJoin
+  module_function
+
+  ALLOWED_RETURN_TO_ORIGINS = %w[
+    https://www.maiocchi.adv.br
+    https://maiocchi.adv.br
+    https://app.maiocchi.adv.br
+  ].freeze
+
+  CALLBACK_PATH = '/api/auth/certificate/callback'
+
+  def enabled?
+    join_url.present? && internal_token.present?
+  end
+
+  def join_url
+    ENV.fetch('UNO_CERTIFICATE_JOIN_URL', '').to_s.strip.presence
+  end
+
+  def internal_token
+    ENV.fetch('UNO_INTERNAL_SERVICE_TOKEN', '').to_s.strip.presence
+  end
+
+  def safe_return_to(raw)
+    return nil if raw.blank? || raw.to_s.length > 4096
+
+    uri = URI.parse(raw.to_s)
+    return nil unless uri.is_a?(URI::HTTPS)
+    return nil if uri.userinfo.present?
+    return nil unless uri.port.nil? || uri.port == 443
+    origin = "#{uri.scheme}://#{uri.host}"
+    return nil unless ALLOWED_RETURN_TO_ORIGINS.include?(origin)
+    return nil unless uri.path == CALLBACK_PATH
+    return nil if uri.fragment.present?
+
+    params = URI.decode_www_form(uri.query.to_s).to_h
+    return nil if (params.keys - %w[next]).any?
+
+    uri.to_s
+  rescue URI::InvalidURIError
+    nil
+  end
+
+  def issue!(email:, subject_dn: nil)
+    raise ArgumentError, 'email required' if email.blank?
+    raise ArgumentError, 'join disabled' unless enabled?
+
+    uri = URI.parse(join_url)
+    raise ArgumentError, 'join url must be https' unless uri.is_a?(URI::HTTPS)
+
+    body = { email: email.to_s.strip }
+    body[:subject_dn] = subject_dn.to_s if subject_dn.present?
+
+    http = Net::HTTP.new(uri.host, uri.port)
+    http.use_ssl = true
+    http.open_timeout = 5
+    http.read_timeout = 10
+    req = Net::HTTP::Post.new(uri.request_uri)
+    req['Content-Type'] = 'application/json'
+    req['Accept'] = 'application/json'
+    req['X-Internal-Token'] = internal_token
+    req.body = JSON.generate(body)
+    res = http.request(req)
+    payload = JSON.parse(res.body.to_s)
+    raise "join mint failed: #{res.code}" unless res.is_a?(Net::HTTPSuccess) && payload['ok'] == true
+    raise 'join mint missing code' if payload['code'].to_s.blank?
+
+    payload['code'].to_s
+  end
+end
