diff --git a/spec/models/certificate_auth/client_certificate_spec.rb b/spec/models/certificate_auth/client_certificate_spec.rb
new file mode 100644
index 0000000..ecfd145
--- /dev/null
+++ b/spec/models/certificate_auth/client_certificate_spec.rb
@@ -0,0 +1,70 @@
+# frozen_string_literal: true
+
+require 'base64'
+require 'cgi'
+
+RSpec.describe CertificateAuth::ClientCertificate do
+  let(:certificate) { build_certificate }
+  let(:encoded_der) { Base64.strict_encode64(certificate.to_der) }
+
+  it 'parses a literal PEM certificate' do
+    parsed = described_class.from_forwarded_header(certificate.to_pem)
+
+    expect(parsed.sha256).to eq(Digest::SHA256.hexdigest(certificate.to_der))
+  end
+
+  it 'parses a percent-encoded PEM without corrupting plus signs' do
+    header = CGI.escape(certificate.to_pem)
+
+    expect(encoded_der).to include('+')
+    expect(header).to include('%2B')
+
+    parsed = described_class.from_forwarded_header(header)
+
+    expect(parsed.sha256).to eq(Digest::SHA256.hexdigest(certificate.to_der))
+  end
+
+  it 'parses the first raw Base64 certificate in a Traefik chain' do
+    other_certificate = build_certificate
+    chained_header = [encoded_der, Base64.strict_encode64(other_certificate.to_der)].join(',')
+
+    parsed_chain = described_class.from_forwarded_header(chained_header)
+
+    expect(parsed_chain.sha256).to eq(Digest::SHA256.hexdigest(certificate.to_der))
+  end
+
+  it 'recovers plus signs already converted to spaces by an upstream decoder' do
+    expect(encoded_der).to include('+')
+
+    recovered = described_class.from_forwarded_header(encoded_der.tr('+', ' '))
+
+    expect(recovered.sha256).to eq(Digest::SHA256.hexdigest(certificate.to_der))
+  end
+
+  it 'rejects malformed Base64 instead of accepting a partial certificate' do
+    expect do
+      described_class.from_forwarded_header("#{encoded_der.delete_suffix('=')}!,ignored")
+    end.to raise_error(ArgumentError, 'invalid certificate')
+  end
+
+  private
+
+  def build_certificate
+    20.times do
+      key = OpenSSL::PKey::EC.generate('prime256v1')
+      candidate = OpenSSL::X509::Certificate.new
+      candidate.version = 2
+      candidate.serial = SecureRandom.random_number(2**64)
+      candidate.subject = OpenSSL::X509::Name.parse('/CN=Usuário de Teste/O=Maiocchi')
+      candidate.issuer = OpenSSL::X509::Name.parse('/CN=AC de Teste/O=ICP-Brasil')
+      candidate.public_key = key
+      candidate.not_before = 1.hour.ago
+      candidate.not_after = 1.year.from_now
+      candidate.sign(key, OpenSSL::Digest.new('SHA256'))
+
+      return candidate if Base64.strict_encode64(candidate.to_der).include?('+')
+    end
+
+    raise 'não foi possível gerar certificado de teste com caractere +'
+  end
+end
