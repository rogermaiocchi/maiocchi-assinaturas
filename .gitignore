# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/.vinext/
/out/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# local orchestration state
/.claude/

# local backup artifacts
/backups/
*.dump
*.tgz

# vercel
.vercel

# typescript
next-env.d.ts
*.tsbuildinfo
/dist/
**/.build/
**/target/
/.wrangler/
/outputs/
/work/

# local browser QA artifacts
/.playwright-mcp/
/portal-desktop.png

# conflict copies produced by local sync; canonical files remain unignored
/app/globals [0-9].css
/clients/*/README [0-9].md
/compliance/SHA256SUMS [0-9]
/compliance/* [0-9].tar.gz

# historical local scanner outputs; current release evidence is 1.3.25+
/compliance/sbom/pki-bridge-1.3.23.cdx.json
/compliance/vulnerability/pki-bridge-1.3.23.grype.json
