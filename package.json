{
  "name": "maiocchi-assinaturas-portal",
  "version": "1.15.1",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:sites": "NEXT_PUBLIC_AUTHENTICITY_API_BASE=${NEXT_PUBLIC_AUTHENTICITY_API_BASE:-https://assinatura.maiocchi.adv.br} SITES_BUILD=1 WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "start": "npx serve out",
    "test": "npm run test:portal && npm run test:pki",
    "test:portal": "npm run build && node --test tests/*.test.mjs",
    "test:pki": "npm --prefix services/pki-bridge test",
    "lint": "eslint . --ignore-pattern out --ignore-pattern .next --ignore-pattern work --ignore-pattern tools/pades-visual-editor/dist --ignore-pattern tools/pades-visual-editor/output"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "mermaid": "^11.16.0",
    "next": "16.2.10",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.44.0",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitejs/plugin-rsc": "^0.5.27",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.10",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "^0.0.50",
    "vite": "^8.1.4",
    "wrangler": "^4.110.0"
  },
  "overrides": {
    "postcss": "8.5.16",
    "sharp": "0.35.3",
    "fast-uri": "3.1.4",
    "minimatch@3.1.5": {
      "brace-expansion": "1.1.16"
    },
    "minimatch@10.2.5": {
      "brace-expansion": "5.0.7"
    }
  },
  "type": "module"
}
